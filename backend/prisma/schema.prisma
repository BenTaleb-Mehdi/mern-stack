generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Admin {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
}

model Client {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  phone       String
  createdAt   DateTime @default(now())
}